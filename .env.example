# ── Meshtastic-es-map config ──────────────────────────────────────────────────
# Copia este fichero como .env y ajusta los valores

# URL de la instancia de meshview desde la que se recogen los datos
MESHVIEW_URL=https://meshview.meshtastic.es

# Puerto público del servidor web
WEB_PORT=8095

# Intervalo del collector en minutos
COLLECTOR_INTERVAL=5

# Ruta de la base de datos dentro de los contenedores
DB_PATH=/data/meshtastic-es-map.db

# Directorio donde el collector escribe los JSON para el frontend
# En Docker: /data/json (montado en nginx como /map/data/)
# En VPS sin Docker: /ruta/al/repo/web/data
JSON_OUT=/data/json

# Posición inicial del mapa
# MAP_AUTO_FIT=true  → ajusta la vista para mostrar todos los nodos al cargar
# MAP_AUTO_FIT=false → usa las coordenadas y zoom definidos abajo
MAP_AUTO_FIT=true
MAP_LAT=40.2
MAP_LNG=-3.7
MAP_ZOOM=8
