# ── Meshtastic-es-map config ──────────────────────────────────────────────────
# Copia este fichero como .env y ajusta los valores

# URL de la instancia de meshview desde la que se recogen los datos
# (también la usa update-top.py, script local de desarrollo;
# si no se exporta, update-top.py usa http://localhost:18085 por defecto)
MESHVIEW_URL=https://meshview.meshtastic.es

# Puerto público del servidor web
WEB_PORT=8095

# Intervalo del collector en minutos
COLLECTOR_INTERVAL=5

# Días que se conservan los nodos en la base de datos (también controla la ventana del mapa)
NODE_RETENTION_DAYS=7

# Ruta de la base de datos dentro de los contenedores
DB_PATH=/data/meshtastic-es-map.db

# Directorio donde el collector escribe los JSON para el frontend
# En Docker: /data/json (montado en nginx como /map/data/)
# En VPS sin Docker: /ruta/al/repo/web/data
JSON_OUT=/data/json

# Posición inicial del mapa
# MAP_AUTO_FIT=true  → ajusta la vista para mostrar todos los nodos al cargar
# MAP_AUTO_FIT=false → usa las coordenadas y zoom definidos abajo
MAP_AUTO_FIT=true
MAP_LAT=40.2
MAP_LNG=-3.7
MAP_ZOOM=8

# URL del JSON con los nodos no optimizados (generado por update-top.py)
# En local: ruta al fichero top-nodos.json generado por update-top.py
MAL_CONFIG_URL=https://datos.meshtastic.es/top-mal-configurados

# Checks de update-top.py a desactivar, separados por comas (vacío = todos activos).
# Claves disponibles: range_test, position_fixed, position_mobile, position_unknown,
# nodeinfo, telemetry_device, telemetry_environment, telemetry_power, routing,
# traceroute_auto, position_flags, hop_limit_high
# Ejemplo para quitar la detección de hop_limit=7 y el range test:
# DISABLED_CHECKS=hop_limit_high,range_test
DISABLED_CHECKS=
